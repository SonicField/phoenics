#include <stdio.h>

phc_descr Data {
    Buffer { int values[4]; int count; },
    Empty {}
};

int main(void) {
    Data d;
    d.tag = Data_Buffer;
    d.Buffer.values[0] = 10;
    d.Buffer.values[1] = 20;
    d.Buffer.count = 2;
    phc_match(Data, d) {
        case Buffer: {
            for (int i = 0; i < d.Buffer.count; i++)
                printf("%d ", d.Buffer.values[i]);
            printf("\n");
        } break;
        case Empty: {
            printf("empty\n");
        } break;
    }
    return 0;
}
