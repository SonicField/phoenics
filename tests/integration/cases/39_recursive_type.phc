#include <stdio.h>
#include <stdlib.h>

phc_descr List;

phc_descr List {
    Cons { int head; List *tail; },
    Nil {}
};

int main(void) {
    List nil = List_mk_Nil();
    List one = List_mk_Cons(1, &nil);
    List two = List_mk_Cons(2, &one);

    List *cur = &two;
    while (cur->tag == List_Cons) {
        printf("%d ", cur->Cons.head);
        cur = cur->Cons.tail;
    }
    printf("\n");
    return 0;
}
