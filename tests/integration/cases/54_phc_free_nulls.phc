#include <stdio.h>
#include <stdlib.h>

phc_descr Dummy { X {} };

int main(void) {
    char *p = malloc(10);
    printf("before: %s\n", p ? "not null" : "null");
    phc_free((void**)&p);
    printf("after: %s\n", p ? "not null" : "null");

    /* Double call — must not crash */
    phc_free((void**)&p);
    printf("double: %s\n", p ? "not null" : "null");

    /* NULL pointer — must not crash */
    char *q = NULL;
    phc_free((void**)&q);
    printf("null safe: %s\n", q ? "not null" : "null");

    return 0;
}
