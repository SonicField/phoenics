#include <stdio.h>

phc_descr Shape {
    Circle { double radius; },
    Rectangle { double width; double height; }
};

int main(void) {
    Shape s = Shape_mk_Circle(3.14);
    phc_match(Shape, s) {
        case Circle(radius): {
            printf("radius=%g\n", radius);
        } break;
        case Rectangle: {
            printf("rect\n");
        } break;
    }
    return 0;
}
