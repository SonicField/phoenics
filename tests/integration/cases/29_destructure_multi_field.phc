#include <stdio.h>

phc_descr Shape {
    Circle { double radius; },
    Rectangle { double width; double height; }
};

int main(void) {
    Shape s = Shape_mk_Rectangle(3.0, 4.0);
    phc_match(Shape, s) {
        case Circle(radius): {
            printf("circle r=%g\n", radius);
        } break;
        case Rectangle(width, height): {
            printf("rect %gx%g area=%g\n", width, height, width * height);
        } break;
    }
    return 0;
}
