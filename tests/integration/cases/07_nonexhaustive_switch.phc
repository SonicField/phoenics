phc_descr Shape {
    Circle { double radius; },
    Rectangle { double width; double height; },
    Triangle { double base; double height; }
};

int main(void) {
    Shape s = Shape_mk_Circle(1.0);
    /* Missing Triangle case — PHC must reject this */
    phc_match(Shape, s) {
        case Circle: { break; }
        case Rectangle: { break; }
    }
    return 0;
}
