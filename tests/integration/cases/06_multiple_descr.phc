#include <stdio.h>

phc_descr Color {
    Red {},
    Green {},
    Blue {}
};

phc_descr Value {
    Integer { int n; },
    Float { double f; },
    String { const char *s; }
};

int main(void) {
    Color c = Color_mk_Red();
    Value v = Value_mk_Integer(42);
    phc_match(Color, c) {
        case Red:   { printf("red\n"); } break;
        case Green: { printf("green\n"); } break;
        case Blue:  { printf("blue\n"); } break;
    }
    phc_match(Value, v) {
        case Integer: { printf("int: %d\n", v.Integer.n); } break;
        case Float:   { printf("float: %f\n", v.Float.f); } break;
        case String:  { printf("string: %s\n", v.String.s); } break;
    }
    return 0;
}
