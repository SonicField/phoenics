#include <stdio.h>

descr Option_int {
    Some { int value; },
    None {}
};

int main(void) {
    Option_int x = Option_int_mk_Some(42);
    switch (x.tag) {
    case Option_int_Some:
        printf("got %d\n", x.Some.value);
        break;
    case Option_int_None:
        printf("nothing\n");
        break;
    }
    return 0;
}
